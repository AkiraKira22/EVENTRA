# ============================================================
# Eventra — Event Registration System — Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file → .env.local
#   2. Fill in the real values in .env.local
#   3. DO NOT commit .env.local to git
# ============================================================

# ------------------------------------------------------------
# MongoDB Atlas
# How to get it: mongodb.com/atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
# ------------------------------------------------------------
MONGODB_URI=

# ------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_URL: your app URL (localhost for dev, domain for prod)
# NEXTAUTH_SECRET: a random 32-byte string
#   Generate in PowerShell:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#   Or in bash/terminal:
#   openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# Google OAuth + Calendar API
# How to get it:
#   1. console.cloud.google.com → New Project "Eventra"
#   2. Enable: Google Calendar API, Google People API
#   3. OAuth Consent Screen → External → fill in the form
#   4. Scopes: email, profile, openid, calendar.events
#   5. Add your email as a Test User
#   6. Credentials → Create OAuth 2.0 Client ID → Web Application
#   7. Authorized redirect URIs:
#      - Development: http://localhost:3000/api/auth/callback/google
#      - Production:  https://your-domain.com/api/auth/callback/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
